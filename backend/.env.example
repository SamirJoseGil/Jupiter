# Cloud PostgreSQL / Supabase
# Example: postgres://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=
DIRECT_URL=

PORT=8000
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated list for multiple frontends (prod, preview, localhost)
# FRONTEND_URLS=http://localhost:5173,https://jupiter.sglabs.site
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
NODE_ENV=development
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# n8n email webhook secret (header x-webhook-secret)
N8N_WEBHOOK_SECRET=change_this_secret

# Optional: force PQR table name when multiple tables exist (pqrs or pqrsdf)
# PQR_TABLE=pqrs

# Cloudflare R2 (S3-compatible) for PQRSDF evidences
CLOUDFLARE_ACCOUNT_ID=206a0fc7c1a601dfd9b020452659e91c
CLOUDFLARE_R2_BUCKET=https://206a0fc7c1a601dfd9b020452659e91c.r2.cloudflarestorage.com/jupiter
CLOUDFLARE_R2_ACCESS_KEY_ID=0e35da1c4e4a4c05084dc6e61caea182
CLOUDFLARE_R2_SECRET_ACCESS_KEY=0f408a82e17024d4f3fa37fdc454457373425f6ef91de198d29b19899b999523

# Optional public base URL, e.g. https://pub-xxxx.r2.dev
CLOUDFLARE_R2_PUBLIC_URL=https://206a0fc7c1a601dfd9b020452659e91c.r2.cloudflarestorage.com/jupiter